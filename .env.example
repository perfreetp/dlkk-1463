APP_NAME=影像质控中心
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=True

DATABASE_URL=postgresql://postgres:password@localhost:5432/imaging_qc
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=imaging_qc

JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

REDIS_URL=redis://localhost:6379/0

LOG_LEVEL=info
LOG_DIR=./logs

SCHEDULER_ENABLED=True
SCHEDULER_TIMEZONE=Asia/Shanghai

QC_SIMILARITY_THRESHOLD=0.65
QC_AUTO_REVIEW_RATIO=0.1
